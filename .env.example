# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/odg_sale?schema=public"

# 32+ random bytes (base64url). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=""

# Warehouse codes (comma-separated) representing the "sales-available" stock pool.
# Used by /api/inventory/sales-balances and as default for /api/inventory/stock-balance.
SALES_WAREHOUSES="1101,1102"

# BCEL OnePay merchant configuration (server-side only)
ONEPAY_BASE_URL="https://bcel.la:8093/onepayservice"
ONEPAY_MCID=""
ONEPAY_MERCHANT_NAME=""
ONEPAY_MCC=""
ONEPAY_SHOPCODE=""
ONEPAY_ACCOUNT_NO=""
ONEPAY_PROVINCE_CODE="VT"
ONEPAY_USERNAME=""
ONEPAY_PASSWORD=""

# Optional fallback used by the current customer display until API
# authentication is configured.
BCEL_QR_PAYLOAD=""

# Firebase Cloud Messaging Service Account JSON string (Required for push notifications)
# FCM_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# FCM_SERVICE_ACCOUNT_JSON=""
